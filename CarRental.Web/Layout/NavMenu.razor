@inject NotificationStateService NotificationState
@inject NotificationHubService NotificationHub
@inject IdentityApiService IdentityApi
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<nav class="cr-nav">

    @* ---- Brand ---- *@
    <a href="/" class="cr-brand">
        <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Class="cr-brand-icon" />
        <span>Car<span class="cr-brand-accent">Rental</span></span>
    </a>

    <AuthorizeView Context="auth">
        <Authorized>

            @* ---- Links (desktop) ---- *@
            <div class="cr-links">
                <NavLink href="/" Match="NavLinkMatch.All" class="cr-link" ActiveClass="cr-link-active">Home</NavLink>
                <NavLink href="/vehicles" class="cr-link" ActiveClass="cr-link-active">@AppStrings.Nav_Vehicles</NavLink>
                <NavLink href="/manufacturers" class="cr-link" ActiveClass="cr-link-active">Manufacturers</NavLink>
                <NavLink href="/locations" class="cr-link" ActiveClass="cr-link-active">Locations</NavLink>
                <NavLink href="/reservations" class="cr-link" ActiveClass="cr-link-active">Reservations</NavLink>
                <NavLink href="/rentals" class="cr-link" ActiveClass="cr-link-active">Rentals</NavLink>
            </div>

            <div class="cr-nav-right">

                @* ---- Links (mobile) ---- *@
                <div class="cr-mobile-menu">
                    <MudMenu Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Dense="true"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem Href="/">Home</MudMenuItem>
                        <MudMenuItem Href="/vehicles">@AppStrings.Nav_Vehicles</MudMenuItem>
                        <MudMenuItem Href="/manufacturers">Manufacturers</MudMenuItem>
                        <MudMenuItem Href="/locations">Locations</MudMenuItem>
                        <MudMenuItem Href="/reservations">Reservations</MudMenuItem>
                        <MudMenuItem Href="/rentals">Rentals</MudMenuItem>
                    </MudMenu>
                </div>

                @* ---- Language switcher ---- *@
                <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Dense="true"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <MudMenuItem OnClick="@(() => SetCultureAsync("en"))">English</MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetCultureAsync("hr"))">Hrvatski</MudMenuItem>
                </MudMenu>

                @* ---- Notifications bell ---- *@
                <MudBadge Content="@NotificationState.UnreadCount" Color="Color.Secondary"
                          Overlap="true" Visible="@(NotificationState.UnreadCount > 0)">
                    <MudMenu Icon="@Icons.Material.Filled.Notifications"
                             Color="Color.Inherit"
                             Dense="true"
                             AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight"
                             OnOpenChanged="OnNotificationsOpenChanged">
                        <div class="cr-notif-panel">
                            @if (NotificationState.Notifications.Count == 0)
                            {
                                <div class="cr-notif-empty">
                                    <MudIcon Icon="@Icons.Material.Outlined.NotificationsNone" Size="Size.Large" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">No notifications.</MudText>
                                </div>
                            }
                            else
                            {
                                @foreach (var n in NotificationState.Notifications)
                                {
                                    <div class="cr-notif-item">
                                        <MudText Typo="Typo.body2"><b>Rental #@n.RentalId overdue</b></MudText>
                                        <MudText Typo="Typo.caption">
                                            @n.VehicleName (@n.RegistrationPlate) — @n.CustomerFullName,
                                            @n.HoursOverdue h late
                                        </MudText>
                                    </div>
                                }
                                <MudButton Size="Size.Small" Class="ma-2"
                                           OnClick="() => NotificationState.Clear()">
                                    Clear all
                                </MudButton>
                            }
                        </div>
                    </MudMenu>
                </MudBadge>

                @* ---- User menu (avatar → email + logout) ---- *@
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                    <ActivatorContent>
                        <MudAvatar Size="Size.Small" Class="cr-avatar">
                            @GetInitial(auth.User.GetEmail())
                        </MudAvatar>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="cr-user-header">
                            <MudText Typo="Typo.body2"><b>@auth.User.GetEmail()</b></MudText>
                        </div>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogoutAsync">
                            Logout
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </div>
        </Authorized>

        <NotAuthorized>
            <div class="cr-nav-right">
                <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Dense="true">
                    <MudMenuItem OnClick="@(() => SetCultureAsync("en"))">English</MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetCultureAsync("hr"))">Hrvatski</MudMenuItem>
                </MudMenu>
                <NavLink href="/login" class="cr-link cr-link-login">Login</NavLink>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</nav>

@code {

    protected override void OnInitialized() =>
        NotificationState.Changed += OnNotificationsChanged;

    private void OnNotificationsChanged() =>
        InvokeAsync(StateHasChanged);

    private void OnNotificationsOpenChanged(bool open)
    {
        if (open)
            NotificationState.MarkAllRead();
    }

    private static string GetInitial(string? email) =>
        string.IsNullOrWhiteSpace(email) ? "?" : email[..1].ToUpperInvariant();

    private async Task SetCultureAsync(string culture)
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "carrental_culture", culture);
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private async Task HandleLogoutAsync()
    {
        await NotificationHub.StopAsync();
        await IdentityApi.LogoutAsync();
        NotificationState.Clear();
        AuthStateProvider.NotifyUserLogout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose() =>
        NotificationState.Changed -= OnNotificationsChanged;
}
