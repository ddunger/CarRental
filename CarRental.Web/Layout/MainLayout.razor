@inherits LayoutComponentBase
@inject NotificationHubService NotificationHub
@inject TokenStorageService TokenStorage
@inject NotificationStateService NotificationState
@implements IDisposable

<MudThemeProvider Theme="@CarRentalTheme.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<NavMenu />

<main class="cr-main">
    <article class="content px-4">
        @Body
    </article>
</main>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@if (_overdueToasts.Count > 0)
{
    <div class="cr-toast-stack">
        @foreach (var n in _overdueToasts)
        {
            <div class="cr-toast">
                <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Size="Size.Small" Class="cr-toast-icon" />
                <div class="cr-toast-body">
                    <strong>Rental #@n.RentalId overdue</strong>
                    <span>@n.VehicleName (@n.RegistrationPlate) — @n.CustomerFullName, @n.HoursOverdue h late</span>
                </div>
                <button class="cr-toast-dismiss" @onclick="() => Dismiss(n)" aria-label="Dismiss">✕</button>
            </div>
        }
    </div>
}

@code {
    private readonly List<RentalOverdueNotification> _overdueToasts = [];

    protected override void OnInitialized() =>
        NotificationHub.RentalOverdueReceived += OnRentalOverdue;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var token = await TokenStorage.GetAccessTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            try
            {
                await NotificationHub.StartAsync();
            }
            catch
            {
                // API down or token expired — page functionality unaffected,
                // connection re-established on next login
            }
        }
    }

    private void OnRentalOverdue(RentalOverdueNotification notification)
    {
        NotificationState.Add(notification);
        _overdueToasts.Add(notification);       // keep the toast as the "live" alert
        InvokeAsync(StateHasChanged);
    }

    private void Dismiss(RentalOverdueNotification n)
    {
        _overdueToasts.Remove(n);
    }

    public void Dispose() =>
        NotificationHub.RentalOverdueReceived -= OnRentalOverdue;
}
