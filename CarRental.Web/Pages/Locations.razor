@page "/locations"
@attribute [Authorize]
@inject LocationApiService LocationApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@AppStrings.Locations_Title — CarRental</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <div class="d-flex align-center mb-4">
        <MudText Typo="Typo.h4">@AppStrings.Locations_Title</MudText>
        <MudSpacer />
        <AuthorizeView Roles="Admin,Manager">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialogAsync">
                @AppStrings.Locations_Add
            </MudButton>
        </AuthorizeView>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else
    {
        <MudExpansionPanels MultiExpansion="false">
            @foreach (var location in _locations)
            {
                <MudExpansionPanel>
                    <TitleContent>
                        <div class="d-flex align-center" style="gap:0.75rem;">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn"
                                     Color="@(location.IsActive ? Color.Primary : Color.Default)" />
                            <MudText>@location.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@location.Address</MudText>
                            @if (!location.IsActive)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@AppStrings.Locations_Inactive</MudChip>
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid>
                            @* --- Working hours --- *@
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.subtitle1" Class="mb-2">@AppStrings.Locations_WorkingHours</MudText>
                                <MudSimpleTable Dense="true">
                                    <tbody>
                                        @foreach (var wh in location.WorkingHours.OrderBy(w => ((int)w.DayOfWeek + 6) % 7))
                                        {
                                            <tr>
                                                <td>@wh.DayOfWeek.Display()</td>
                                                <td>
                                                    @if (wh.IsClosed)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@AppStrings.Locations_Closed</MudChip>
                                                    }
                                                    else
                                                    {
                                                        @($"{wh.OpenTime:HH\\:mm} – {wh.CloseTime:HH\\:mm}")
                                                    }
                                                </td>
                                                <td style="text-align:right;">
                                                    <AuthorizeView Roles="Admin,Manager" Context="auth">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       OnClick="() => OpenEditHoursDialogAsync(location, wh)" />
                                                    </AuthorizeView>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>

                            @* --- Holidays --- *@
                            <MudItem xs="12" md="6">
                                <div class="d-flex align-center mb-2">
                                    <MudText Typo="Typo.subtitle1">@AppStrings.Locations_Holidays</MudText>
                                    <MudSpacer />
                                    <AuthorizeView Roles="Admin,Manager" Context="auth">
                                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                                                   OnClick="() => OpenAddHolidayDialogAsync(location)">
                                            @AppStrings.Common_Add
                                        </MudButton>
                                    </AuthorizeView>
                                </div>
                                @if (location.Holidays.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@AppStrings.Locations_NoHolidays</MudText>
                                }
                                else
                                {
                                    <MudSimpleTable Dense="true">
                                        <tbody>
                                            @foreach (var h in location.Holidays.OrderBy(h => h.Date))
                                            {
                                                <tr>
                                                    <td>@h.Date.ToString("yyyy-MM-dd")</td>
                                                    <td>@(h.HolidayName ?? "—")</td>
                                                    <td>
                                                        @if (h.IsClosed)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@AppStrings.Locations_Closed</MudChip>
                                                        }
                                                        else
                                                        {
                                                            @($"{h.OpenTime:HH\\:mm} – {h.CloseTime:HH\\:mm}")
                                                        }
                                                    </td>
                                                    <td style="text-align:right;">
                                                        <AuthorizeView Roles="Admin" Context="auth">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                           Color="Color.Error"
                                                                           OnClick="() => ConfirmDeleteHolidayAsync(location, h)" />
                                                        </AuthorizeView>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                            </MudItem>

                            @* --- Location actions --- *@
                            <MudItem xs="12" Class="d-flex" Style="gap:0.5rem;">
                                <AuthorizeView Roles="Admin,Manager" Context="auth">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                               StartIcon="@Icons.Material.Filled.Edit"
                                               OnClick="() => OpenEditDialogAsync(location)">
                                        @AppStrings.Locations_EditLocation
                                    </MudButton>
                                </AuthorizeView>
                                <AuthorizeView Roles="Admin" Context="auth">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               OnClick="() => ConfirmDeleteAsync(location)">
                                        @AppStrings.Locations_DeleteLocation
                                    </MudButton>
                                </AuthorizeView>
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    }
</MudContainer>

@code {
    private List<LocationResponse> _locations = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _locations = await LocationApi.GetAllAsync();
        _loading = false;
    }

    private async Task OpenCreateDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<LocationDialog>(AppStrings.Locations_DialogTitle_Add);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: CreateLocationRequest request })
        {
            var (success, error) = await LocationApi.CreateAsync(request);
            await HandleResultAsync(success, error, AppStrings.Locations_Created);
        }
    }

    private async Task OpenEditDialogAsync(LocationResponse location)
    {
        var parameters = new DialogParameters<LocationDialog>
        {
            { d => d.Existing, location }
        };

        var dialog = await DialogService.ShowAsync<LocationDialog>(AppStrings.Locations_DialogTitle_Edit, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: CreateLocationRequest request })
        {
            var update = new UpdateLocationRequest(
                request.Name, request.Address, request.Latitude, request.Longitude, null);

            var (success, error) = await LocationApi.UpdateAsync(location.Id, update);
            await HandleResultAsync(success, error, AppStrings.Locations_Updated);
        }
    }

    private async Task ConfirmDeleteAsync(LocationResponse location)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { d => d.Message, string.Format(AppStrings.Locations_DeleteConfirm, location.Name) }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(AppStrings.Locations_DialogTitle_Delete, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var (success, error) = await LocationApi.DeleteAsync(location.Id);
            await HandleResultAsync(success, error, AppStrings.Locations_Deleted);
        }
    }

    private async Task OpenEditHoursDialogAsync(LocationResponse location, WorkingHoursResponse hours)
    {
        var parameters = new DialogParameters<WorkingHoursDialog>
        {
            { d => d.Existing, hours }
        };

        var dialog = await DialogService.ShowAsync<WorkingHoursDialog>(
            $"{hours.DayOfWeek.Display()} — {location.Name}", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: UpdateWorkingHoursRequest request })
        {
            var (success, error) = await LocationApi.UpdateWorkingHoursAsync(location.Id, hours.Id, request);
            await HandleResultAsync(success, error, AppStrings.Locations_HoursUpdated);
        }
    }

    private async Task OpenAddHolidayDialogAsync(LocationResponse location)
    {
        var dialog = await DialogService.ShowAsync<HolidayDialog>(
            $"{AppStrings.Locations_DialogTitle_AddHoliday} — {location.Name}");
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AddHolidayRequest request })
        {
            var (success, error) = await LocationApi.AddHolidayAsync(location.Id, request);
            await HandleResultAsync(success, error, AppStrings.Locations_HolidayAdded);
        }
    }

    private async Task ConfirmDeleteHolidayAsync(LocationResponse location, HolidayResponse holiday)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { d => d.Message, string.Format(AppStrings.Locations_DeleteHolidayConfirm,
                holiday.Date.ToString("yyyy-MM-dd"), holiday.HolidayName ?? "—") }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(AppStrings.Locations_DialogTitle_DeleteHoliday, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var (success, error) = await LocationApi.DeleteHolidayAsync(location.Id, holiday.Id);
            await HandleResultAsync(success, error, AppStrings.Locations_HolidayDeleted);
        }
    }

    private async Task HandleResultAsync(bool success, string? error, string successMessage)
    {
        if (success)
        {
            Snackbar.Add(successMessage, Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(error ?? AppStrings.Common_OperationFailed, Severity.Error);
        }
    }
}